// ─────────────────────────────────────────────────────
// Resume & Template Models
// ─────────────────────────────────────────────────────

model ResumeTemplate {
  id           String           @id @default(cuid())
  name         String
  description  String?
  thumbnailUrl String // Preview image (MinIO)
  htmlLayout   String // Handlebars HTML string
  cssStyles    String // Scoped CSS for this template
  category     TemplateCategory
  isActive     Boolean          @default(true)
  isDefault    Boolean          @default(false)
  isFeatured   Boolean          @default(false) // Show on landing carousel
  displayOrder Int              @default(0) // Featured carousel order
  createdBy    String // Admin userId
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  resumes Resume[]

  @@index([isFeatured, isActive, displayOrder])
  @@map("resume_template")
}

model Resume {
  id              String       @id @default(cuid())
  userId          String
  templateId      String
  title           String
  type            ResumeType   @default(RESUME)
  status          ResumeStatus @default(DRAFT)
  targetJobTitle  String? // For ATS optimization
  jobDescription  String? // Pasted JD for ATS scoring
  atsScore        Int? // 0-100 ATS compatibility score
  contentData     Json // Structured resume content
  aiSuggestions   Json? // AI improvement suggestions
  pdfUrl          String? // MinIO URL of exported PDF
  version         Int          @default(1)
  isPublic        Boolean      @default(false)
  slug            String?      @unique // Public share slug (/r/:slug)
  disabledByAdmin Boolean      @default(false) // Admin moderation toggle
  noindex         Boolean      @default(false) // Hide from search engines
  views           ResumeView[] // Public-link analytics
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template ResumeTemplate  @relation(fields: [templateId], references: [id])
  history  ResumeHistory[]

  @@index([isPublic, disabledByAdmin])
  @@map("resume")
}

model ResumeHistory {
  id        String   @id @default(cuid())
  resumeId  String
  version   Int
  snapshot  Json // Full contentData snapshot at this version
  changedBy String // userId of editor
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("resume_history")
}

// ─── Public Resume Share Analytics ───────────────────
// Records a single view / download of /r/:slug. The viewerHash
// is a SHA-256 of (ip + userAgent + day-bucket) so we can dedupe
// without storing PII.
model ResumeView {
  id         String   @id @default(cuid())
  resumeId   String
  eventType  String // "view" | "download"
  viewerHash String? // anonymized visitor fingerprint
  referrer   String?
  userAgent  String?
  ipAddress  String?
  country    String? // optional geo lookup (ISO-3166 alpha-2)
  isBot      Boolean  @default(false)
  createdAt  DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, eventType, createdAt])
  @@index([resumeId, viewerHash, createdAt])
  @@map("resume_view")
}
