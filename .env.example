# ── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://profileai:profileai_secret@localhost:5432/profileai

# ── Auth (BetterAuth) ──────────────────────────────────────
BETTER_AUTH_SECRET=your_super_secret_better_auth_key_minimum_32_chars
BETTER_AUTH_URL=http://localhost:5000
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_minimum_32_chars
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_minimum_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

# ── 2FA (AES-256-GCM) ──────────────────────────────────────
# Must be exactly 32 characters
TOTP_ENCRYPTION_KEY=your_32_character_encryption_key!!

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenRouter AI ─────────────────────────────────────────
OpenRouter_API_KEY=sk-or-v1-your_openrouter_api_key

# ── Puppeteer PDF Service ───────────────────────────────────
PUPPETEER_SERVICE_URL=http://localhost:3001

# ── MinIO Object Storage ───────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=profileai
MINIO_USE_SSL=false

# ── Email / SMTP ────────────────────────────────────────────
EMAIL_SENDER_SMTP_HOST=localhost
EMAIL_SENDER_SMTP_PORT=1025
EMAIL_SENDER_SMTP_USER=noreply@profileai.com
EMAIL_SENDER_SMTP_PASS=
EMAIL_SENDER_SMTP_FROM=ProFile AI <noreply@profileai.com>
